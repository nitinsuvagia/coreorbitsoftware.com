# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Office Management SaaS - AWS EC2 Deployment
# ===========================================
#
# IMPORTANT: Copy this file to .env.production and fill in all values
# DO NOT commit .env.production to version control!
#
# cp .env.production.example .env.production
#
# ===========================================

# ===========================================
# DOMAIN CONFIGURATION
# ===========================================
NODE_ENV=production
APP_NAME="Office Management System"
APP_URL=https://portal.coreorbitsoftware.com
API_URL=https://api.coreorbitsoftware.com
PUBLIC_WEBSITE_URL=https://www.coreorbitsoftware.com

# Next.js Public Variables
NEXT_PUBLIC_API_URL=https://api.coreorbitsoftware.com
NEXT_PUBLIC_APP_URL=https://portal.coreorbitsoftware.com
NEXT_PUBLIC_PORTAL_URL=https://portal.coreorbitsoftware.com
NEXT_PUBLIC_WEBSITE_URL=https://www.coreorbitsoftware.com

# ===========================================
# DATABASE - PostgreSQL
# ===========================================
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DB_NAME=oms_master
DB_HOST=postgres
DB_PORT=5432

# Full connection URL (uses Docker service name)
MASTER_DATABASE_URL=postgresql://postgres:CHANGE_THIS_TO_STRONG_PASSWORD@postgres:5432/oms_master

# ===========================================
# REDIS
# ===========================================
REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_THIS_TO_STRONG_PASSWORD@redis:6379

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# Generate with: openssl rand -base64 48
JWT_SECRET=GENERATE_A_STRONG_64_CHARACTER_SECRET_KEY_HERE
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=GENERATE_ANOTHER_STRONG_64_CHARACTER_SECRET_KEY
JWT_REFRESH_EXPIRES_IN=30d

# Encryption Key (32 characters) - Generate with: openssl rand -hex 16
ENCRYPTION_KEY=GENERATE_32_CHARACTER_KEY_HERE!!

# ===========================================
# SSO CONFIGURATION (Optional)
# ===========================================
SSO_ENABLED=false
# SSO_ISSUER=https://your-company.okta.com
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_CALLBACK_URL=https://api.coreorbitsoftware.com/api/auth/sso/callback

# ===========================================
# AWS CONFIGURATION
# ===========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# S3 Configuration
AWS_S3_BUCKET=coreorbit-oms-uploads
AWS_S3_TENANT_BUCKET_PREFIX=coreorbit-tenant

# SQS Configuration
AWS_SQS_QUEUE_PREFIX=coreorbit-oms
AWS_SQS_REGION=us-east-1

# SNS Configuration
AWS_SNS_TOPIC_PREFIX=coreorbit-oms

# ===========================================
# EMAIL (AWS SES or SMTP)
# ===========================================
# Option 1: AWS SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=YOUR_SES_SMTP_USER
# SMTP_PASSWORD=YOUR_SES_SMTP_PASSWORD

# Option 2: External SMTP (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_SECURE=false

EMAIL_FROM=noreply@coreorbitsoftware.com
EMAIL_FROM_NAME="CoreOrbit Office Management"

# ===========================================
# INTERNAL SERVICE URLS (Docker Network)
# ===========================================
AUTH_SERVICE_URL=http://auth-service:3001
EMPLOYEE_SERVICE_URL=http://employee-service:3002
ATTENDANCE_SERVICE_URL=http://attendance-service:3003
PROJECT_SERVICE_URL=http://project-service:3004
TASK_SERVICE_URL=http://task-service:3005
BILLING_SERVICE_URL=http://billing-service:3006
DOCUMENT_SERVICE_URL=http://document-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008
REPORT_SERVICE_URL=http://report-service:3009
AI_SERVICE_URL=http://ai-service:3012

# ===========================================
# SERVICE PORTS (Internal)
# ===========================================
GATEWAY_PORT=4000
WEB_PORT=3000
PUBLIC_WEBSITE_PORT=3100
AUTH_SERVICE_PORT=3001
EMPLOYEE_SERVICE_PORT=3002
ATTENDANCE_SERVICE_PORT=3003
PROJECT_SERVICE_PORT=3004
TASK_SERVICE_PORT=3005
BILLING_SERVICE_PORT=3006
DOCUMENT_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
REPORT_SERVICE_PORT=3009
AI_SERVICE_PORT=3012

# ===========================================
# FILE UPLOAD
# ===========================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,gif,csv

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ===========================================
# FEATURE FLAGS
# ===========================================
FEATURE_RECRUITMENT=true
FEATURE_PAYROLL=true
FEATURE_ASSET_MANAGEMENT=true
FEATURE_CLIENT_PORTAL=true
FEATURE_AI_ASSISTANT=true

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# MONITORING (Optional)
# ===========================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEW_RELIC_LICENSE_KEY=your-license-key
# DATADOG_API_KEY=your-api-key

# ===========================================
# STRIPE PAYMENTS (Optional)
# ===========================================
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================================
# AI SERVICE (Optional)
# ===========================================
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
